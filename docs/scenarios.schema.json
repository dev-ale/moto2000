{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moto2000.dev/schema/scenario-v1.json",
  "title": "ScramScreen Ride Scenario",
  "description": "A replayable motorcycle ride described as a timeline of sensor samples and events. See docs/scenarios.md for the full description.",
  "type": "object",
  "required": [
    "version",
    "name",
    "summary",
    "durationSeconds",
    "locationSamples",
    "headingSamples",
    "motionSamples",
    "weatherSnapshots",
    "nowPlayingSnapshots",
    "callEvents",
    "calendarEvents"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "durationSeconds": { "type": "number", "minimum": 0 },
    "locationSamples": {
      "type": "array",
      "items": { "$ref": "#/$defs/locationSample" }
    },
    "headingSamples": {
      "type": "array",
      "items": { "$ref": "#/$defs/headingSample" }
    },
    "motionSamples": {
      "type": "array",
      "items": { "$ref": "#/$defs/motionSample" }
    },
    "weatherSnapshots": {
      "type": "array",
      "items": { "$ref": "#/$defs/weatherSnapshot" }
    },
    "nowPlayingSnapshots": {
      "type": "array",
      "items": { "$ref": "#/$defs/nowPlayingSnapshot" }
    },
    "callEvents": {
      "type": "array",
      "items": { "$ref": "#/$defs/callEvent" }
    },
    "calendarEvents": {
      "type": "array",
      "items": { "$ref": "#/$defs/calendarEvent" }
    }
  },
  "$defs": {
    "scenarioTime": {
      "type": "number",
      "minimum": 0,
      "description": "Seconds since the scenario started."
    },
    "locationSample": {
      "type": "object",
      "required": ["scenarioTime", "latitude", "longitude"],
      "properties": {
        "scenarioTime": { "$ref": "#/$defs/scenarioTime" },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "altitudeMeters": { "type": "number" },
        "speedMps": { "type": "number" },
        "courseDegrees": { "type": "number" },
        "horizontalAccuracyMeters": { "type": "number", "minimum": 0 }
      }
    },
    "headingSample": {
      "type": "object",
      "required": ["scenarioTime", "magneticDegrees"],
      "properties": {
        "scenarioTime": { "$ref": "#/$defs/scenarioTime" },
        "magneticDegrees": { "type": "number", "minimum": 0, "maximum": 360 },
        "trueDegrees": { "type": "number" }
      }
    },
    "motionSample": {
      "type": "object",
      "required": ["scenarioTime", "gravityX", "gravityY", "gravityZ"],
      "properties": {
        "scenarioTime": { "$ref": "#/$defs/scenarioTime" },
        "gravityX": { "type": "number" },
        "gravityY": { "type": "number" },
        "gravityZ": { "type": "number" },
        "userAccelX": { "type": "number" },
        "userAccelY": { "type": "number" },
        "userAccelZ": { "type": "number" }
      }
    },
    "weatherSnapshot": {
      "type": "object",
      "required": [
        "scenarioTime",
        "condition",
        "temperatureCelsius",
        "highCelsius",
        "lowCelsius",
        "locationName"
      ],
      "properties": {
        "scenarioTime": { "$ref": "#/$defs/scenarioTime" },
        "condition": {
          "type": "string",
          "enum": ["clear", "cloudy", "rain", "snow", "fog", "thunderstorm"]
        },
        "temperatureCelsius": { "type": "number" },
        "highCelsius": { "type": "number" },
        "lowCelsius": { "type": "number" },
        "locationName": { "type": "string" }
      }
    },
    "nowPlayingSnapshot": {
      "type": "object",
      "required": [
        "scenarioTime",
        "title",
        "artist",
        "album",
        "isPlaying",
        "positionSeconds",
        "durationSeconds"
      ],
      "properties": {
        "scenarioTime": { "$ref": "#/$defs/scenarioTime" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "album": { "type": "string" },
        "isPlaying": { "type": "boolean" },
        "positionSeconds": { "type": "number", "minimum": 0 },
        "durationSeconds": { "type": "number", "minimum": 0 }
      }
    },
    "callEvent": {
      "type": "object",
      "required": ["scenarioTime", "state", "callerHandle"],
      "properties": {
        "scenarioTime": { "$ref": "#/$defs/scenarioTime" },
        "state": {
          "type": "string",
          "enum": ["incoming", "connected", "ended"]
        },
        "callerHandle": { "type": "string" }
      }
    },
    "calendarEvent": {
      "type": "object",
      "required": ["scenarioTime", "title", "startsInSeconds", "location"],
      "properties": {
        "scenarioTime": { "$ref": "#/$defs/scenarioTime" },
        "title": { "type": "string" },
        "startsInSeconds": { "type": "number" },
        "location": { "type": "string" }
      }
    }
  }
}
